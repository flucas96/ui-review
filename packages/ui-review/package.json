{
  "name": "ui-review",
  "version": "0.4.0",
  "description": "Local-first visual feedback for web applications and coding agents",
  "type": "module",
  "bin": {
    "ui-review": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/flucas96/ui-review#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flucas96/ui-review.git"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "http-proxy": "^1.18.1",
    "zod": "^4.4.3"
  }
}
